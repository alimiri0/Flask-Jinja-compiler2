from flask import Flask, render_template, request, url_for

app = Flask(__name__)

@app.route("/")
def index():
    user = {
        "name": "Omar",
        "is_admin": True,
        "theme": "dark"
    }

    products = [
        {"id": 1, "name": "Phone", "price": 500, "on_sale": True},
        {"id": 2, "name": "Laptop", "price": 1200, "on_sale": False}
    ]

    discount = 0.15
    max_price = max(p["price"] for p in products)

    return render_template(
        "index.html",
        user=user,
        products=products,
        discount=discount,
        max_price=max_price,
        link=url_for("index")
    )

